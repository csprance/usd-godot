[configuration]

entry_symbol = "godot_usd_init"
compatibility_minimum = "4.1"

[libraries]

macos.debug = "res://addons/godot-usd/bin/libgodot-usd.dylib"
macos.release = "res://addons/godot-usd/bin/libgodot-usd.dylib"
windows.debug.x86_64 = "res://addons/godot-usd/bin/godot-usd.dll"
windows.release.x86_64 = "res://addons/godot-usd/bin/godot-usd.dll"
linux.debug.x86_64 = "res://addons/godot-usd/bin/libgodot-usd.so"
linux.release.x86_64 = "res://addons/godot-usd/bin/libgodot-usd.so"

[dependencies]

macos = {}
windows = {}
linux = {}
